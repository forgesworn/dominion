{
  "name": "dominion-protocol",
  "version": "0.1.0",
  "description": "Epoch-based encrypted access control protocol for Nostr",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./nostr": {
      "import": "./dist/nostr/index.js",
      "types": "./dist/nostr/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "LICENSE",
    "llms.txt"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "nostr",
    "encryption",
    "access-control",
    "epoch",
    "aes-gcm",
    "hkdf",
    "shamir",
    "tiered-access",
    "content-keys",
    "dominion"
  ],
  "sideEffects": false,
  "author": "forgesworn",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/forgesworn/dominion.git"
  },
  "homepage": "https://github.com/forgesworn/dominion",
  "bugs": {
    "url": "https://github.com/forgesworn/dominion/issues"
  },
  "dependencies": {
    "@noble/ciphers": "^2.1.0",
    "@noble/hashes": "^2.0.1"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@types/node": "^25.3.3",
    "semantic-release": "^25.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "funding": {
    "type": "lightning",
    "url": "lightning:thedonkey@strike.me"
  }
}
